# T1D Command Center - Environment Variables
# Copy this file to .env.local and fill in values.

# ──────────────────────────────────────────────
# Database (Supabase Postgres)
# ──────────────────────────────────────────────
# Local dev: use Docker Compose (port 5452)
# DATABASE_URL=postgresql://postgres:postgres@localhost:5452/t1d_command_center
#
# Supabase: Settings → Database → Connection string
DATABASE_URL=

# ──────────────────────────────────────────────
# Supabase Auth & API
# ──────────────────────────────────────────────
# Find these in: Supabase Dashboard → Settings → API
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
# ──────────────────────────────────────────────
# App
# ──────────────────────────────────────────────
NODE_ENV=development

# ──────────────────────────────────────────────
# Demo Accounts (create in Supabase Auth → Users)
# ──────────────────────────────────────────────
# clinician@t1d-demo.app  / demo-clinician-2026
# educator@t1d-demo.app   / demo-educator-2026
# admin@t1d-demo.app      / demo-admin-2026
#
# Disable email confirmation in:
# Supabase Dashboard → Authentication → Providers → Email → Confirm email = OFF
