# T1D Command Center - Environment Variables
# Copy this file to .env.local and fill in values.

# Database
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/t1d_command_center

# Redis
REDIS_URL=redis://localhost:6379

# App
NODE_ENV=development
PORT=3000
API_PORT=3001

# Auth (mock mode for development)
AUTH_MODE=mock
MOCK_USER_ROLE=clinician

# Locale defaults
DEFAULT_LOCALE=en

# Logging
LOG_LEVEL=debug
